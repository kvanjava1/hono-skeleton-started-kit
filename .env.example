# ====================
# Application
# ====================
PORT=8080
NODE_ENV=development
LOG_RETENTION_DAYS=3

# ====================
# Database Toggles (true/false)
# ====================
DB_MONGO_ENABLED=false
DB_MYSQL_ENABLED=false
DB_PG_ENABLED=false
DB_SQLITE_ENABLED=true
DB_REDIS_ENABLED=true

# ====================
# Redis Configuration
# ====================
REDIS_HOST_1=172.17.0.1
REDIS_PORT_1=6379

REDIS_HOST_2=172.17.0.1
REDIS_PORT_2=6380

# ====================
# Queue Configuration
# ====================
QUEUE_CONCURRENCY=5
QUEUE_REMOVE_ON_COMPLETE=true
QUEUE_REMOVE_ON_FAIL=100

# ====================
# MongoDB Configuration
# ====================
MONGO_HOST_1=172.17.0.1
MONGO_PORT_1=27017
MONGO_DB_NAME_1=myapp

MONGO_HOST_2=172.17.0.1
MONGO_PORT_2=27017
MONGO_DB_NAME_2=myapp_2

# ====================
# MySQL Configuration
# ====================
MYSQL_HOST_1=172.17.0.1
MYSQL_PORT_1=3306
MYSQL_USER_1=root
MYSQL_PASSWORD_1=rootadmin
MYSQL_DATABASE_1=myapp

MYSQL_HOST_2=172.17.0.1
MYSQL_PORT_2=3306
MYSQL_USER_2=root
MYSQL_PASSWORD_2=rootadmin
MYSQL_DATABASE_2=myapp_2

# ====================
# PostgreSQL Configuration
# ====================
PG_HOST_1=localhost
PG_PORT_1=5432
PG_USER_1=postgres
PG_PASSWORD_1=
PG_DATABASE_1=myapp

PG_HOST_2=localhost
PG_PORT_2=5432
PG_USER_2=postgres
PG_PASSWORD_2=
PG_DATABASE_2=myapp_2

# ====================
# SQLite Configuration
# ====================
SQLITE_DB_PATH_1=./storages/database/sqlite/sqlite1.dev.db

# ====================
# Rate Limiter
# ====================
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=900000

# ====================
# CORS
# ====================
CORS_ORIGIN=*
